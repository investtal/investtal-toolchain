// investtal-toolchain CI + multi-tool auto-release (main only).
// GitHub Actions are not used. GitHub Releases = distribution only.
//
// Why 9cc unit runs macOS-strict decode on Linux: a previous bug shipped
// `9cc update` broken because macOS `base64 -d` rejects line-wrapped base64
// while Linux tolerates it. Unit tests shim base64 for macOS strictness
// (Cycle 14c). A real macOS agent (label `macos`) is attempted in the matrix
// stage when present.
//
// IVT-1707 / IVT-0610.

pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        // Hermetic: 9cc unit tests + smoke must never depend on the host's ~/.9cc.
        CC9_HOME = "${env.WORKSPACE}/.ci-home"
        CC9_BIN_DIR = "${env.WORKSPACE}/.ci-bin"
        // Skip local git hooks during release commits on the agent.
        IVT_HOOK_SKIP = '1'
    }

    stages {
        stage('9cc unit + smoke') {
            steps {
                sh '''
                    set -e
                    mkdir -p "$CC9_HOME" "$CC9_BIN_DIR"
                    # Smoke-check the launcher parses before exercising it.
                    bash -n 9cc/9cc.sh
                    bash -n 9cc/smoke.sh
                    bash 9cc/9cc.test.sh
                    bash 9cc/smoke.sh
                '''
            }
        }

        stage('Release scripts unit') {
            steps {
                sh 'bash scripts/release/tests/run.sh'
            }
        }

        stage('Atlassian unit + smoke') {
            steps {
                // Agent /bin/sh is often dash (no pipefail). Force bash.
                sh '''#!/usr/bin/env bash
                    set -euo pipefail
                    # shellcheck source=/dev/null
                    source scripts/release/lib.sh
                    # shellcheck source=/dev/null
                    source scripts/release/ensure-zig.sh
                    ensure_zig
                    (
                      cd atlassian
                      zig build test
                      zig build
                      ./scripts/smoke.sh ./zig-out/bin/atlassian
                    )
                '''
            }
        }

        stage('Matrix: real macOS 9cc') {
            // Fleet is Ubuntu-only today; stage no-ops until a `macos` agent exists.
            // Use offline:true so an offline mac agent still counts as "available to schedule"
            // without a hard failure. Empty label → quiet skip (no "Configuration error").
            steps {
                script {
                    def macAgent = []
                    try {
                        // offline: true includes offline agents; empty list is fine.
                        macAgent = nodesByLabel(label: 'macos', offline: true)
                    } catch (ignored) {
                        macAgent = []
                    }
                    if (macAgent) {
                        node('macos') {
                            sh '''
                                set -e
                                bash 9cc/9cc.test.sh
                                bash 9cc/smoke.sh
                            '''
                        }
                    } else {
                        echo 'IVT-0610: skip real macOS (no agent with label macos). ' +
                             'Linux stage already runs the macOS-strict base64 shim (Cycle 14c).'
                    }
                }
            }
        }

        stage('Auto release (main)') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-token-userpass',
                    usernameVariable: 'GIT_USERNAME',
                    passwordVariable: 'GH_TOKEN'
                )]) {
                    sh '''#!/usr/bin/env bash
                        set -euo pipefail
                        export GITHUB_TOKEN="$GH_TOKEN"
                        export GH_TOKEN
                        export GIT_USERNAME

                        # Agent preflight: required tools for release orchestration
                        missing=""
                        for c in gh curl git; do
                          command -v "$c" >/dev/null 2>&1 || missing="${missing} ${c}"
                        done
                        # PR title parse: gh --jq preferred; else python3/node/jq for curl path
                        if ! command -v python3 >/dev/null 2>&1 \
                           && ! command -v node >/dev/null 2>&1 \
                           && ! command -v jq >/dev/null 2>&1; then
                          # gh alone is enough (has --jq); only flag if gh missing too
                          if ! command -v gh >/dev/null 2>&1; then
                            missing="${missing} python3|node|jq"
                          fi
                        fi
                        # zip is optional: package-atlassian falls back to python3 zipfile
                        if [ -n "$missing" ]; then
                          echo "release preflight: missing required tools:${missing}" >&2
                          exit 1
                        fi

                        git fetch --tags --prune
                        # Shallow clones break HEAD^ / change detection — deepen when possible
                        git fetch --unshallow 2>/dev/null || git fetch --deepen=50 || true

                        # BASE_SHA: first parent of merge commit when available
                        if git rev-parse -q --verify HEAD^2 >/dev/null; then
                          export BASE_SHA="$(git rev-parse HEAD^1)"
                        elif BASE_SHA="$(git rev-parse HEAD^ 2>/dev/null)"; then
                          export BASE_SHA
                        elif BASE_SHA="$(git rev-parse HEAD~1 2>/dev/null)"; then
                          export BASE_SHA
                        else
                          echo "release: cannot resolve BASE_SHA (need git history: --unshallow/--deepen)" >&2
                          exit 1
                        fi
                        bash scripts/release/run-auto-release.sh
                    '''
                }
            }
        }
    }

    post {
        always {
            sh 'rm -rf "$CC9_HOME" "$CC9_BIN_DIR" || true'
            // Only archive when a release stage produced files under dist/
            // (PR builds never do). allowEmptyArchive alone still logs
            // "Configuration error?" for empty globs — skip the step entirely.
            script {
                def hasDist = sh(
                    script: 'find dist -type f 2>/dev/null | head -1 | grep -q .',
                    returnStatus: true
                ) == 0
                if (hasDist) {
                    archiveArtifacts artifacts: 'dist/**/*', allowEmptyArchive: true
                } else {
                    echo 'No dist/ artifacts to archive (normal for PR / non-release runs).'
                }
            }
            cleanWs()
        }
        unsuccessful {
            echo 'toolchain CI failed — check 9cc/atlassian tests or release scripts'
        }
    }
}
